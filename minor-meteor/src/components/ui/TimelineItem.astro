---
import type { ExperienceItem } from '../../data/experience';
import TechTag from './TechTag.astro';

interface Props {
  item: ExperienceItem;
  last?: boolean;
}
const { item, last = false } = Astro.props;
---

<div class="group relative flex gap-6">
  <!-- Left: line + dot -->
  <div class="flex flex-col items-center">
    <div class:list={[
      'w-3 h-3 rounded-full flex-shrink-0 mt-1.5 transition-all duration-300 z-10',
      item.current
        ? 'bg-[var(--color-accent)] ring-4 ring-[rgba(0,173,216,0.2)] group-hover:ring-[rgba(0,173,216,0.4)]'
        : 'bg-[var(--color-surface-2)] border-2 border-[rgba(255,255,255,0.15)] group-hover:border-[var(--color-accent)]'
    ]}></div>
    {!last && (
      <div class="w-px flex-1 mt-2 bg-[rgba(255,255,255,0.07)] min-h-[2rem]"></div>
    )}
  </div>

  <!-- Right: content -->
  <div class="pb-8 flex-1">
    <div class="flex flex-wrap items-center gap-2 mb-1">
      <span class="text-xs font-mono text-[var(--color-accent)] bg-[rgba(0,173,216,0.1)] px-2 py-0.5 rounded">
        {item.period}
      </span>
      {item.current && (
        <span class="text-xs font-mono text-[var(--color-accent-2)] bg-[rgba(16,185,129,0.1)] px-2 py-0.5 rounded flex items-center gap-1">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent-2)] inline-block" style="animation: pulse-dot 2s ease-in-out infinite;"></span>
          Current
        </span>
      )}
    </div>

    <h3 class="font-bold text-[var(--color-text)] text-lg leading-tight group-hover:text-white transition-colors duration-300">
      {item.role}
    </h3>
    <p class="text-[var(--color-accent)] font-medium text-sm mt-0.5 transition-colors duration-300">
      {item.company}
      <span class="text-[var(--color-muted)] font-normal"> · {item.location}</span>
    </p>

    <ul class="mt-3 space-y-1.5">
      {item.highlights.map(h => (
        <li class="flex items-start gap-2 text-sm text-[var(--color-muted)]">
          <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">›</span>
          <span>{h}</span>
        </li>
      ))}
    </ul>

    {item.stack && item.stack.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-3">
        {item.stack.map(tag => <TechTag tag={tag} />)}
      </div>
    )}
  </div>
</div>
