---
import type { Project } from '../../data/projects';
import TechTag from './TechTag.astro';

interface Props {
  project: Project;
}
const { project } = Astro.props;
---

<article class="card group flex flex-col p-6 gap-4 relative overflow-hidden">
  {project.highlight && (
    <div class="absolute top-4 right-4">
      <span class="text-xs font-mono px-2 py-1 rounded-full bg-[rgba(0,173,216,0.15)] text-[var(--color-accent)] border border-[rgba(0,173,216,0.3)]">
        Featured
      </span>
    </div>
  )}

  <!-- Icon + Title -->
  <div class="flex items-start gap-3">
    <div class="w-10 h-10 rounded-lg bg-[rgba(0,173,216,0.1)] border border-[rgba(0,173,216,0.2)] flex items-center justify-center flex-shrink-0 transition-all duration-300 group-hover:bg-[rgba(0,173,216,0.2)] group-hover:border-[rgba(0,173,216,0.4)]">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-accent)]">
        <polyline points="16 18 22 12 16 6"></polyline>
        <polyline points="8 6 2 12 8 18"></polyline>
      </svg>
    </div>
    <div>
      <h3 class="font-bold text-[var(--color-text)] text-lg leading-tight group-hover:text-white transition-colors duration-300">
        {project.title}
      </h3>
      <p class="text-[var(--color-accent)] text-sm font-mono mt-0.5">{project.subtitle}</p>
    </div>
  </div>

  <!-- Description -->
  <p class="text-[var(--color-muted)] text-sm leading-relaxed flex-1" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
    {project.description}
  </p>

  <!-- Stack tags -->
  <div class="flex flex-wrap gap-1.5">
    {project.stack.map(tag => <TechTag tag={tag} />)}
  </div>

  <!-- GitHub link -->
  <div class="flex items-center justify-between pt-2 border-t border-[rgba(255,255,255,0.05)]">
    <a
      href={project.github}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-2 text-[var(--color-muted)] text-sm hover:text-[var(--color-accent)] transition-colors duration-300"
      aria-label={`View ${project.title} on GitHub`}
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
      </svg>
      View on GitHub
    </a>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-muted)] group-hover:text-[var(--color-accent)] transition-colors duration-300 group-hover:translate-x-1 group-hover:-translate-y-1 transform">
      <line x1="7" y1="17" x2="17" y2="7"></line>
      <polyline points="7 7 17 7 17 17"></polyline>
    </svg>
  </div>
</article>
