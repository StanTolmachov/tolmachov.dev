---
---

<footer id="contact" class="relative mt-8 border-t border-[rgba(255,255,255,0.05)]">
  <!-- Gradient top glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-px bg-gradient-to-r from-transparent via-[var(--color-accent)] to-transparent opacity-40"></div>

  <div class="max-w-5xl mx-auto px-6 md:px-12 py-16">
    <!-- Top: CTA block -->
    <div class="text-center mb-16">
      <p class="font-mono text-[var(--color-accent)] text-sm mb-3">04. contact</p>
      <h2 class="text-3xl md:text-4xl font-bold text-[var(--color-text)] mb-4">Let's Build Something Together</h2>
      <p class="text-[var(--color-muted)] max-w-md mx-auto mb-8">
        Open to backend Go roles, technical leadership positions, and interesting remote opportunities.
      </p>
      <a href="mailto:stan@tolmachov.dev" class="btn-primary text-base px-8 py-3">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
        stan@tolmachov.dev
      </a>
    </div>

    <!-- Divider -->
    <div class="border-t border-[rgba(255,255,255,0.05)] mb-10"></div>

    <!-- Bottom: logo + links + copyright -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo + name -->
      <div class="flex items-center gap-3">
        <span class="font-mono font-bold text-xl text-[var(--color-accent)]">ST</span>
        <div>
          <p class="font-semibold text-[var(--color-text)] text-sm">Stanislav Tolmachov</p>
          <p class="text-xs text-[var(--color-muted)]">Backend Go Engineer</p>
        </div>
      </div>

      <!-- Contact info -->
      <div class="flex flex-col items-center gap-1 text-sm text-[var(--color-muted)]">
        <a href="mailto:stan@tolmachov.dev" class="hover:text-[var(--color-accent)] transition-colors duration-300">
          stan@tolmachov.dev
        </a>
        <a href="tel:+4792043450" class="hover:text-[var(--color-accent)] transition-colors duration-300">
          +47 920 43 450
        </a>
      </div>

      <!-- Social icons -->
      <div class="flex items-center gap-4">
        <a href="https://github.com/StanTolmachov" target="_blank" rel="noopener noreferrer" aria-label="GitHub"
          class="text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-all duration-300 hover:-translate-y-1">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/stan-tolmachov/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"
          class="text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-all duration-300 hover:-translate-y-1">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a href="https://t.me/StasTolmachov" target="_blank" rel="noopener noreferrer" aria-label="Telegram"
          class="text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-all duration-300 hover:-translate-y-1">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-8 pt-6 border-t border-[rgba(255,255,255,0.04)] flex flex-col md:flex-row items-center justify-between gap-2 text-xs text-[var(--color-muted)]">
      <p>© 2026 Stanislav Tolmachov. All rights reserved.</p>
      <p class="font-mono">Built with precision. Hosted on GitHub Pages.</p>
    </div>
  </div>
</footer>
