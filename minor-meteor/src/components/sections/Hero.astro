---
---

<section id="hero" class="relative min-h-screen flex flex-col justify-center overflow-hidden">
  <!-- Dot grid background -->
  <div class="absolute inset-0 dot-grid opacity-60 pointer-events-none"></div>

  <!-- Gradient blobs -->
  <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(0,173,216,0.06) 0%, transparent 70%); filter: blur(40px);"></div>
  <div class="absolute bottom-1/4 right-1/4 w-80 h-80 rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(16,185,129,0.05) 0%, transparent 70%); filter: blur(40px);"></div>

  <!-- Nav -->
  <nav class="absolute top-0 left-0 right-0 flex items-center justify-between px-6 md:px-12 py-6 z-20">
    <a href="#hero" class="font-mono font-bold text-lg text-[var(--color-accent)] hover:text-white transition-colors duration-300">
      ST<span class="text-[var(--color-muted)]">.dev</span>
    </a>
    <div class="hidden md:flex items-center gap-8">
      {['About', 'Experience', 'Projects', 'Contact'].map(item => (
        <a
          href={`#${item.toLowerCase()}`}
          class="text-sm text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-300 relative group"
        >
          {item}
          <span class="absolute -bottom-0.5 left-0 w-0 h-px bg-[var(--color-accent)] transition-all duration-300 group-hover:w-full"></span>
        </a>
      ))}
    </div>
    <a
      href="mailto:stan@tolmachov.dev"
      class="hidden md:flex btn-secondary text-sm py-2 px-4"
    >
      Hire me
    </a>
  </nav>

  <!-- Main content -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 md:px-12 pt-24 pb-16">

    <!-- Available badge -->
    <div class="animate-fade-in-up delay-100 inline-flex items-center gap-2 mb-8 px-3 py-1.5 rounded-full border border-[rgba(16,185,129,0.3)] bg-[rgba(16,185,129,0.05)]">
      <span class="w-2 h-2 rounded-full bg-[var(--color-accent-2)]" style="animation: pulse-dot 2s ease-in-out infinite;"></span>
      <span class="text-xs font-mono text-[var(--color-accent-2)]">Available for opportunities</span>
    </div>

    <!-- Name -->
    <h1 class="animate-fade-in-up delay-200 text-5xl md:text-7xl font-extrabold tracking-tight leading-none mb-4">
      <span class="text-[var(--color-text)]">Stanislav</span><br />
      <span class="gradient-text">Tolmachov</span>
    </h1>

    <!-- Subtitle -->
    <p class="animate-fade-in-up delay-300 font-mono text-[var(--color-accent)] text-lg md:text-xl mb-3">
      Backend Go Engineer <span class="text-[var(--color-muted)]">|</span> Technical Leader
    </p>

    <!-- Location -->
    <p class="animate-fade-in-up delay-400 flex items-center gap-2 text-[var(--color-muted)] text-sm mb-6">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
        <circle cx="12" cy="10" r="3"></circle>
      </svg>
      Nordreisa, Norway
    </p>

    <!-- Hook text -->
    <p class="animate-fade-in-up delay-500 text-[var(--color-muted)] text-base md:text-lg max-w-2xl leading-relaxed mb-10">
      Building <span class="text-[var(--color-text)]">robust, scalable Go systems</span>, backed by a decade of
      <span class="text-[var(--color-text)]">zero-fault tolerance leadership</span> in the global film industry.
    </p>

    <!-- CTA buttons -->
    <div class="animate-fade-in-up delay-600 flex flex-wrap items-center gap-4 mb-12">
      <a href="#projects" class="btn-primary">
        View Projects
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
      <a href="#contact" class="btn-secondary">
        Contact
      </a>
    </div>

    <!-- Social icons -->
    <div class="animate-fade-in-up delay-700 flex items-center gap-5">
      <a
        href="https://github.com/StanTolmachov"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-all duration-300 hover:-translate-y-1"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
      <a
        href="https://www.linkedin.com/in/stan-tolmachov/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-all duration-300 hover:-translate-y-1"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a
        href="https://t.me/StasTolmachov"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Telegram"
        class="text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-all duration-300 hover:-translate-y-1"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-fade-in delay-700">
    <span class="text-xs font-mono text-[var(--color-muted)]">scroll</span>
    <div class="w-px h-8 bg-gradient-to-b from-[var(--color-muted)] to-transparent"></div>
  </div>
</section>
