---
import { experience } from '../../data/experience';
import TimelineItem from '../ui/TimelineItem.astro';
---

<section id="experience" class="py-24 px-6 md:px-12" style="background: linear-gradient(180deg, transparent 0%, rgba(15,22,36,0.5) 50%, transparent 100%);">
  <div class="max-w-3xl mx-auto">
    <!-- Section header -->
    <div class="mb-12">
      <p class="font-mono text-[var(--color-accent)] text-sm mb-2">03. experience</p>
      <h2 class="section-title">Career Timeline</h2>
      <p class="section-subtitle">A decade of technical leadership, now focused on Go engineering.</p>
    </div>

    <!-- Timeline -->
    <div>
      {experience.map((item, i) => (
        <TimelineItem item={item} last={i === experience.length - 1} />
      ))}
    </div>
  </div>
</section>
