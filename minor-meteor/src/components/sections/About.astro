---
import BentoCard from '../ui/BentoCard.astro';
---

<section id="about" class="py-24 px-6 md:px-12 max-w-5xl mx-auto">
  <!-- Section header -->
  <div class="mb-12">
    <p class="font-mono text-[var(--color-accent)] text-sm mb-2">01. about</p>
    <h2 class="section-title">The Engineer Behind the Code</h2>
    <p class="section-subtitle max-w-xl">From managing Oscar-nominated film pipelines to building Go microservices.</p>
  </div>

  <!-- Bento Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">

    <!-- Story tile — wide -->
    <BentoCard class="lg:col-span-2" accent>
      <div class="flex items-center gap-2 mb-1">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
        <span class="text-xs font-mono text-[var(--color-accent)]">story</span>
      </div>
      <h3 class="font-bold text-[var(--color-text)] text-lg">From Film Labs to Go Services</h3>
      <p class="text-[var(--color-muted)] text-sm leading-relaxed">
        For over a decade, I ran a digital film laboratory delivering post-production for
        <span class="text-[var(--color-text)] font-medium">Netflix, Amazon, Lionsgate</span> — including the
        <span class="text-[var(--color-text)] font-medium">Oscar-nominated "Winter on Fire"</span>.
        I managed multi-terabyte data pipelines, maintained Linux/SAN infrastructure with
        <span class="text-[var(--color-accent-2)] font-medium">0% downtime</span>, and led teams of 10+ under extreme deadlines.
      </p>
      <p class="text-[var(--color-muted)] text-sm leading-relaxed">
        That zero-fault tolerance mindset now drives my backend engineering: Clean Architecture,
        reliable gRPC services, and systems that simply don't fail.
      </p>
    </BentoCard>

    <!-- Tech Stack tile -->
    <BentoCard>
      <div class="flex items-center gap-2 mb-1">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="16 18 22 12 16 6"></polyline>
          <polyline points="8 6 2 12 8 18"></polyline>
        </svg>
        <span class="text-xs font-mono text-[var(--color-accent)]">tech stack</span>
      </div>
      <h3 class="font-bold text-[var(--color-text)] text-base mb-3">Core Arsenal</h3>
      <div class="grid grid-cols-2 gap-2">
        {[
          { name: 'Go', icon: '🐹' },
          { name: 'gRPC', icon: '⚡' },
          { name: 'PostgreSQL', icon: '🐘' },
          { name: 'Redis', icon: '🔴' },
          { name: 'Docker', icon: '🐳' },
          { name: 'GitHub Actions', icon: '⚙️' },
        ].map(item => (
          <div class="flex items-center gap-2 text-sm text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-200">
            <span class="text-base">{item.icon}</span>
            <span class="font-mono text-xs">{item.name}</span>
          </div>
        ))}
      </div>
      <div class="mt-3 pt-3 border-t border-[rgba(255,255,255,0.05)]">
        <p class="text-xs text-[var(--color-muted)] font-mono">Clean Architecture · Microservices · TDD</p>
      </div>
    </BentoCard>

    <!-- Soft Skills tile -->
    <BentoCard>
      <div class="flex items-center gap-2 mb-1">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
        </svg>
        <span class="text-xs font-mono text-[var(--color-accent)]">soft skills</span>
      </div>
      <h3 class="font-bold text-[var(--color-text)] text-base mb-3">Leadership DNA</h3>
      <ul class="space-y-2">
        {[
          'Extreme ownership',
          'Crisis management',
          'Zero-fault tolerance',
          'Cross-team leadership',
          'Architectural thinking',
        ].map(skill => (
          <li class="flex items-center gap-2 text-sm text-[var(--color-muted)]">
            <span class="w-1 h-1 rounded-full bg-[var(--color-accent)] flex-shrink-0"></span>
            {skill}
          </li>
        ))}
      </ul>
    </BentoCard>

    <!-- Location tile -->
    <BentoCard>
      <div class="flex items-center gap-2 mb-1">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
          <circle cx="12" cy="10" r="3"></circle>
        </svg>
        <span class="text-xs font-mono text-[var(--color-accent)]">location</span>
      </div>
      <div class="flex items-center gap-3 mt-1">
        <span class="text-3xl">🇳🇴</span>
        <div>
          <p class="font-bold text-[var(--color-text)]">Norway</p>
          <p class="text-xs text-[var(--color-accent-2)] font-mono mt-0.5">✓ Open to remote worldwide</p>
        </div>
      </div>
    </BentoCard>

    <!-- Languages tile -->
    <BentoCard>
      <div class="flex items-center gap-2 mb-1">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="2" y1="12" x2="22" y2="12"></line>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
        </svg>
        <span class="text-xs font-mono text-[var(--color-accent)]">languages</span>
      </div>
      <div class="space-y-2 mt-1">
        {[
          { lang: 'English', level: 'B2', flag: '🇬🇧', width: '70%' },
          { lang: 'Ukrainian', level: 'C2', flag: '🇺🇦', width: '100%' },
          { lang: 'Russian', level: 'C2', flag: '🇷🇺', width: '100%' },
        ].map(l => (
          <div>
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm text-[var(--color-muted)] flex items-center gap-1.5">
                <span>{l.flag}</span> {l.lang}
              </span>
              <span class="text-xs font-mono text-[var(--color-accent)]">{l.level}</span>
            </div>
            <div class="h-1 rounded-full bg-[rgba(255,255,255,0.05)]">
              <div class="h-1 rounded-full bg-gradient-to-r from-[var(--color-accent)] to-[var(--color-accent-2)]" style={`width: ${l.width}`}></div>
            </div>
          </div>
        ))}
      </div>
    </BentoCard>

  </div>
</section>
